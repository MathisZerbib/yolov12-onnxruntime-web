{
  "name": "yolov12-onnxruntime-web",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "overrides": {
    "adm-zip": "0.6.0",
    "tmp": "0.2.7"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names web,api \"vite\" \"wrangler dev --port 8787\"",
    "dev:web": "vite",
    "dev:api": "wrangler dev --port 8787",
    "db:migrate:local": "wrangler d1 migrations apply crossflow-auth --local",
    "worker:check": "wrangler deploy --dry-run --outdir /tmp/crossflow-worker",
    "worker:types": "wrangler types worker-configuration.d.ts --include-runtime false",
    "worker:types:check": "wrangler types worker-configuration.d.ts --include-runtime false --check",
    "worker:typecheck": "tsc -p tsconfig.worker.json",
    "contract:compile": "solcjs --base-path . --include-path node_modules --optimize --bin --abi contracts/TrafficPredictionMarket.sol -o /tmp/crossflow-solc",
    "contract:artifact": "node scripts/build-contract-artifact.mjs",
    "contract:test": "hardhat test solidity",
    "test": "npm run test:unit && npm run test:worker",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "check": "npm run lint && npm run worker:types:check && npm run worker:typecheck && npm run test:unit:coverage && npm run test:worker && npm run contract:test && npm run contract:artifact && npm run build && npm run worker:check && npm run contract:compile && npm audit --omit=dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.548.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "^1.23.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-dropzone": "^19.1.1",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.3.1",
    "viem": "^2.55.0",
    "wagmi": "^3.7.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@eslint/js": "^9.39.4",
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "happy-dom": "^20.11.0",
    "hardhat": "^3.10.0",
    "solc": "0.8.36",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
